# ── Database (Supabase) ──────────────────────────────────────────────────────
# Use the "Transaction" mode pooler URL (region-specific, port 6543) for serverless (Vercel)
# Format: postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Example (this project): postgresql://postgres.suufzrifwupjatqbhowq:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# Get region from Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=LifeOS <noreply@yourdomain.com>

# ── App URL ──────────────────────────────────────────────────────────────────
# After deploying to Vercel, update this to your production URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
