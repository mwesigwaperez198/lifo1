# ── Database (Supabase) ──────────────────────────────────────────────────────
# Go to Supabase Dashboard → Settings → Database → Connection string → URI
# Use the "Transaction" mode pooler URL for serverless (Vercel)
DATABASE_URL=postgresql://postgres.[YOUR_REF]:[%Rebecalove@1]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=LifeOS <noreply@yourdomain.com>

# ── App URL ──────────────────────────────────────────────────────────────────
# After deploying to Vercel, update this to your production URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
